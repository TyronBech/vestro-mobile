{
  "expo": {
    "name": "Vestro",
    "slug": "vestro",
    "scheme": "vestro",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "statusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#fdfefe",
      "translucent": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.vestro",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "navigationBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#fdfefe"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ed130af-0b1a-409f-b1e1-502d80c23f3e"
      }
    },
    "owner": "tyronbech"
  }
}
